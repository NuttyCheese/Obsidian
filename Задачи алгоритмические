Задачи алгоритмические

Задача: Напишите функцию, которая проверяет, являются ли скобки в строке сбалансированными.

Решение:
```swift
func isValid(_ s: String) -> Bool {
    var stack: [Character] = []
    let matchingBrackets: [Character: Character] = [")": "(", "}": "{", "]": "["]
    
    for char in s {
        if matchingBrackets.values.contains(char) {
            stack.append(char)
        } else if let match = matchingBrackets[char], stack.last == match {
            stack.removeLast()
        } else {
            return false
        }
    }
    
    return stack.isEmpty
}

// Пример использования
let validString = "{[()]}"
let invalidString = "{[(])}"
print(isValid(validString))  // true
print(isValid(invalidString))  // false
```

Задача: Реализуйте алгоритм сортировки слиянием.

Решение:
```swift
func mergeSort(_ array: [Int]) -> [Int] {
    guard array.count > 1 else { return array }
    
    let middleIndex = array.count / 2
    let leftArray = mergeSort(Array(array[0..<middleIndex]))
    let rightArray = mergeSort(Array(array[middleIndex..<array.count]))
    
    return merge(leftArray, rightArray)
}

func merge(_ left: [Int], _ right: [Int]) -> [Int] {
    var leftIndex = 0
    var rightIndex = 0
    var result: [Int] = []
    
    while leftIndex < left.count && rightIndex < right.count {
        if left[leftIndex] < right[rightIndex] {
            result.append(left[leftIndex])
            leftIndex += 1
        } else {
            result.append(right[rightIndex])
            rightIndex += 1
        }
    }
    
    result.append(contentsOf: left[leftIndex..<left.count])
    result.append(contentsOf: right[rightIndex..<right.count])
    
    return result
}

// Пример использования
let unsortedArray = [3, 1, 4, 1, 5, 9, 2, 6, 5, 3, 5]
let sortedArray = mergeSort(unsortedArray)
print(sortedArray)  // [1, 1, 2, 3, 3, 4, 5, 5, 5, 6, 9]
```

Задача: Найдите среднее двух отсортированных массивов.

Решение:
```swift
func findMedianSortedArrays(_ nums1: [Int], _ nums2: [Int]) -> Double {
    let mergedArray = mergeSort(nums1 + nums2)
    let count = mergedArray.count
    
    if count % 2 == 0 {
        return Double(mergedArray[count / 2 - 1] + mergedArray[count / 2]) / 2.0
    } else {
        return Double(mergedArray[count / 2])
    }
}

