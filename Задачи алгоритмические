func isValid(_ s: String) -> Bool {
    var stack = [Character]()
    let matching: [Character: Character] = ["(": ")", "[": "]", "{": "}"]
    
    for char in s {
        if matching.keys.contains(char) {
            stack.append(char)
        } else if stack.isEmpty || matching[stack.removeLast()] != char {
            return false
        }
    }
    
    return stack.isEmpty
}
